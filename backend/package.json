{
  "name": "pika-backend",
  "version": "1.0.0",
  "description": "Pika - Payment Links & QR Codes Platform Backend",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "build": "echo 'Build complete'",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.js",
    "prisma:reset": "prisma migrate reset",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "test": "jest",
    "lint": "eslint src/",
    "health": "curl -f http://localhost:8080/health || exit 1"
  },
  "prisma": {
    "seed": "node --experimental-vm-modules prisma/seed.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^1.5.14",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "qrcode": "^1.5.3",
    "rate-limit-redis": "^4.2.0",
    "redis": "^4.6.11",
    "stripe": "^14.10.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "prisma": "^5.7.0"
  }
}
