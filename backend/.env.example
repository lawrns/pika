# Pika Backend Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================
# Application Configuration
# ============================================
NODE_ENV=production
PORT=8080
API_BASE_URL=https://your-domain.fly.dev

# ============================================
# Database (PostgreSQL)
# ============================================
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/pika

# For connection pooling (recommended for production)
DATABASE_URL_POOLED=

# ============================================
# Redis Configuration
# ============================================
# Format: redis://user:password@host:port
REDIS_URL=redis://localhost:6379

# ============================================
# Security
# ============================================
# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Session Secret (generate with: openssl rand -base64 32)
SESSION_SECRET=your-super-secret-session-key-min-32-chars

# Encryption Key for sensitive data (must be 32 characters)
ENCRYPTION_KEY=your-32-char-encryption-key!!

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=https://your-frontend.com,https://app.your-frontend.com

# ============================================
# Stripe Configuration
# ============================================
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# Mercado Pago Configuration
# ============================================
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
MERCADOPAGO_WEBHOOK_SECRET=your-webhook-secret
MERCADOPAGO_PUBLIC_KEY=APP_USR-...

# ============================================
# SPEI/CoDi Configuration (STiPago)
# ============================================
SPEI_ENABLED=true
STIPAGO_API_KEY=your-stipago-api-key
STIPAGO_SECRET_KEY=your-stipago-secret
STIPAGO_WEBHOOK_SECRET=your-webhook-secret

# SPEI Account Configuration
SPEI_CLABE_PRODUCTION=646180123400000001
SPEI_BANK_NAME=STiPago Bank
SPEI_CLABE_SANDBOX=646180123400000001

# ============================================
# Feature Flags
# ============================================
# Enable/disable payment methods
ENABLE_STRIPE=true
ENABLE_MERCADOPAGO=true
ENABLE_SPEI=true
ENABLE_CODI=true

# ============================================
# Monitoring & Logging
# ============================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# ============================================
# Rate Limiting
# ============================================
# Global rate limit window (in minutes)
RATE_LIMIT_WINDOW_MS=15

# Global rate limit max requests
RATE_LIMIT_MAX=100

# ============================================
# Email Configuration (optional)
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@pika.mx

# ============================================
# Webhook Configuration
# ============================================
# Webhook retry attempts
WEBHOOK_MAX_RETRIES=5

# Webhook timeout (in seconds)
WEBHOOK_TIMEOUT=30

# ============================================
# Appwrite Configuration (optional)
# ============================================
# Only needed if using Appwrite as the document store.
# If unset, the server falls back to PostgreSQL document store.
# APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
# APPWRITE_PROJECT_ID=your-project-id
# APPWRITE_API_KEY=your-api-key

